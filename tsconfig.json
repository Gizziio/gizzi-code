{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/bun/tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": [],
    "noUncheckedIndexedAccess": false,
    "customConditions": ["browser"],
    "paths": {
      "@/*": ["./src/*"],
      "@tui/*": ["./src/cli/ui/tui/*"]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "github/**/*",
    "packages/**/*",
    "sdks/**/*",
    "shared/**/*",
    "script/**/*"
  ],
  "exclude": [
    "dist",
    "infra",
    "node_modules",
    "output",
    "migration",
    "packages/sdk/dist"
  ]
}
