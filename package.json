{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "1.0.1",
  "name": "@allternit/gizzi-code",
  "description": "AI-powered terminal interface for the Allternit ecosystem",
  "type": "module",
  "license": "MIT",
  "homepage": "https://docs.gizziio.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gizziio/allternit-platform.git",
    "directory": "cmd/gizzi-code"
  },
  "bugs": {
    "url": "https://github.com/Gizziio/allternit-platform/issues"
  },
  "keywords": [
    "allternitchitect",
    "shell",
    "terminal",
    "tui",
    "cli",
    "gizzi-code"
  ],
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test --timeout 30000",
    "build": "bun run script/build.ts",
    "dev": "bun run --conditions=browser ./src/cli/main.ts",
    "start": "bun run --conditions=browser ./src/cli/main.ts",
    "fix:hang": "bash script/fix-hang.sh",
    "e2e:clerk-login": "bun run script/terminal-clerk-e2e.ts",
    "e2e:tui:visual": "bash script/tui-visual-e2e.sh",
    "e2e:tui:regression": "bash script/tui-visual-regression.sh",
    "random": "echo 'Random script updated at $(date)' && echo 'Change queued successfully' && echo 'Another change made' && echo 'Yet another change' && echo 'One more change' && echo 'Final change' && echo 'Another final change' && echo 'Yet another final change'",
    "clean": "echo 'Cleaning up...' && rm -rf node_modules dist",
    "lint": "echo 'Running lint checks...' && bun test --coverage",
    "format": "echo 'Formatting code...' && bun run --prettier --write src/**/*.ts",
    "docs": "echo 'Generating documentation...' && find src -name '*.ts' -exec echo 'Processing: {}' \\;",
    "deploy": "echo 'Deploying application...' && bun run build && echo 'Deployment completed successfully'",
    "db": "bun drizzle-kit"
  },
  "bin": {
    "gizzi": "./dist/gizzi-code",
    "gizzi-code": "./dist/gizzi-code"
  },
  "exports": {
    "./*": "./src/*.ts"
  },
  "devDependencies": {
    "@babel/core": "7.28.4",
    "@hey-api/openapi-ts": "^0.94.1",
    "@octokit/webhooks-types": "7.6.1",
    "@parcel/watcher-darwin-arm64": "2.5.1",
    "@parcel/watcher-darwin-x64": "2.5.1",
    "@parcel/watcher-linux-arm64-glibc": "2.5.1",
    "@parcel/watcher-linux-arm64-musl": "2.5.1",
    "@parcel/watcher-linux-x64-glibc": "2.5.1",
    "@parcel/watcher-linux-x64-musl": "2.5.1",
    "@parcel/watcher-win32-x64": "2.5.1",
    "@tsconfig/bun": "*",
    "@types/babel__core": "7.20.5",
    "@types/bun": "*",
    "@types/mime-types": "3.0.1",
    "@types/turndown": "5.0.5",
    "@types/yargs": "17.0.33",
    "drizzle-kit": "1.0.0-beta.12-a5629fb",
    "drizzle-orm": "1.0.0-beta.12-a5629fb",
    "typescript": "*",
    "vscode-languageserver-types": "3.17.5",
    "why-is-node-running": "3.2.2",
    "zod-to-json-schema": "3.24.5"
  },
  "dependencies": {
    "@allternit/plugin": "workspace:*",
    "@allternit/script": "workspace:*",
    "@allternit/sdk": "workspace:*",
    "@allternit/util": "workspace:*",
    "@actions/core": "1.11.1",
    "@actions/github": "6.0.1",
    "@agentclientprotocol/sdk": "0.14.1",
    "@ai-sdk/anthropic": "2.0.65",
    "@ai-sdk/google": "2.0.54",
    "@ai-sdk/mistral": "2.0.27",
    "@ai-sdk/openai": "2.0.89",
    "@ai-sdk/openai-compatible": "1.0.32",
    "@ai-sdk/provider": "2.0.1",
    "@ai-sdk/provider-utils": "3.0.21",
    "@clack/prompts": "1.0.0-alpha.1",
    "@hono/standard-validator": "0.1.5",
    "@hono/zod-validator": "*",
    "@modelcontextprotocol/sdk": "1.25.2",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.12.18",
    "@octokit/graphql": "9.0.2",
    "@octokit/rest": "*",
    "@openauthjs/openauth": "*",
    "@opentui/core": "0.1.87",
    "@opentui/solid": "0.1.87",
    "@parcel/watcher": "2.5.1",
    "@pierre/diffs": "*",
    "@solid-primitives/event-bus": "1.1.2",
    "@solid-primitives/scheduled": "1.5.2",
    "@standard-schema/spec": "1.0.0",
    "@upstash/context7-mcp": "^2.1.4",
    "@zip.js/zip.js": "2.7.62",
    "ai": "5.0.124",
    "bonjour-service": "1.3.0",
    "bun-pty": "0.4.8",
    "chokidar": "4.0.3",
    "clipboardy": "4.0.0",
    "decimal.js": "10.5.0",
    "diff": "*",
    "drizzle-orm": "1.0.0-beta.12-a5629fb",
    "fuzzysort": "3.1.0",
    "glob": "13.0.5",
    "gray-matter": "4.0.3",
    "hono": "*",
    "hono-openapi": "*",
    "ignore": "7.0.5",
    "jsonc-parser": "3.3.1",
    "marked": "^17.0.4",
    "mime-types": "3.0.2",
    "minimatch": "10.0.3",
    "moment-timezone": "^0.6.0",
    "open": "10.1.2",
    "opentui-spinner": "0.0.6",
    "partial-json": "0.1.7",
    "remeda": "*",
    "solid-js": "*",
    "strip-ansi": "7.1.2",
    "tree-sitter-bash": "0.25.0",
    "turndown": "7.2.0",
    "ulid": "*",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "web-tree-sitter": "0.25.10",
    "xdg-basedir": "5.1.0",
    "yargs": "18.0.0",
    "zod": "4.3.6",
    "zod-to-json-schema": "3.24.5"
  },
  "overrides": {
    "drizzle-orm": "1.0.0-beta.12-a5629fb"
  }
}