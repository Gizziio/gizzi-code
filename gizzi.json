{
  "$schema": "https://gizzi.io/config.json",
  "model": "moonshotai/kimi-k2-thinking",
  "mcp": {
    "sequential-thinking": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-sequential-thinking"]
