/**
 * Skill Generator - AI-guided skill creation
 * 
 * Uses LLM to interview the user and generate complete skill structure.
 * The user just describes what they want, the AI handles all technical details.
 */

import { generateObject, streamText, type ModelMessage } from "ai"
import { Provider } from "@/runtime/providers/provider"
import { Instance } from "@/runtime/context/project/instance"
import { Log } from "@/shared/util/log"
import path from "path"
import fs from "fs/promises"
import { Filesystem } from "@/shared/util/filesystem"
import { SkillCreator, type SkillTemplate } from "./creator"

const log = Log.create({ service: "skill-generator" })

// Schema for LLM-generated skill structure
export interface GeneratedSkill {
  /** Kebab-case skill name */
  name: string
  
  /** Short description */
  description: string
  
  /** Best matching template */
  template: SkillTemplate
  
  /** Why this template was chosen */
  templateReasoning: string
  
  /** Complete SKILL.md content */
  skillMd: string
  
  /** Scripts to include (filename -> content) */
  scripts?: Record<string, string>
  
  /** References to include (filename -> content) */
  references?: Record<string, string>
  
  /** Example usage scenarios */
  examples: {
    userQuery: string
    expectedBehavior: string
  }[]
}

export interface SkillGenerationInput {
  /** User's natural language description of what they want */
  userDescription: string
  
  /** Optional follow-up Q&A from interview */
  interviewQa?: { question: string; answer: string }[]
  
  /** Target model */
  model?: { providerID: string; modelID: string }
}

/**
 * Interview questions to ask the user
 */
const INTERVIEW_QUESTIONS = [
  "What problem are you trying to solve?",
  "What kind of input will users provide to this skill?",
  "What should the output or result look like?",
  "Are there any external tools, APIs, or file formats involved?",
  "Can you give me a specific example of how someone would use this?",
]

/**
 * System prompt for skill generation
 */
const SKILL_GENERATION_SYSTEM_PROMPT = `You are an expert at creating skills for AI agents.

A "skill" is a specialized capability that helps AI agents accomplish tasks. It consists of:
- SKILL.md: Documentation with usage examples and guidelines
- scripts/: Executable scripts (Python, Bash, etc.)
- references/: Documentation and schemas
- assets/: Templates and other files

Your job is to:
1. Analyze the user's needs
2. Choose the best template (minimal, tool-integration, data-processing, workflow-automation)
3. Generate complete, production-ready skill content
4. Include relevant scripts and references based on the use case

Rules:
- Skill names must be kebab-case (e.g., "pdf-processor", "github-pr-analyzer")
- SKILL.md must include practical examples
- Scripts should be complete and functional
- Choose templates wisely:
  - "tool-integration": For API integrations, external service calls
  - "data-processing": For transforming, analyzing data
  - "workflow-automation": For multi-step processes
  - "minimal": For simple knowledge/documentation skills`

/**
 * Generate interview questions based on user's initial description
 */
export async function generateInterviewQuestions(
  description: string
): Promise<string[]> {
  const config = await Instance.provider.modelConfig()
  
  const prompt = `Given this skill description: "${description}"

Generate 3-5 follow-up questions to better understand what the user needs.
Focus on:
- What inputs the skill will receive
- What outputs it should produce
- Any external tools or APIs involved
- Specific use cases and examples

Return ONLY the questions, one per line.`

  try {
    const result = await streamText({
      model: config.provider,
      messages: [{ role: "user", content: prompt }],
      temperature: 0.7,
    })

    const text = result.text || ""
    const questions = text
      .split("\n")
      .map((q) => q.trim().replace(/^\d+\.\s*/, "").replace(/^-\s*/, ""))
      .filter((q) => q.length > 10 && q.endsWith("?"))
      .slice(0, 5)

    return questions.length > 0 ? questions : INTERVIEW_QUESTIONS.slice(0, 3)
  } catch (error) {
    log.error("Failed to generate interview questions", { error })
    return INTERVIEW_QUESTIONS.slice(0, 3)
  }
}

/**
 * Generate complete skill structure from user description
 */
export async function generateSkill(
  input: SkillGenerationInput
): Promise<GeneratedSkill> {
  const config = input.model 
    ? await Provider.getModel(input.model.providerID, input.model.modelID)
    : await Instance.provider.modelConfig()

  // Build context from interview Q&A
  let context = `User's description: ${input.userDescription}\n\n`
  if (input.interviewQa && input.interviewQa.length > 0) {
    context += "Follow-up Q&A:\n"
    for (const qa of input.interviewQa) {
      context += `Q: ${qa.question}\nA: ${qa.answer}\n\n`
    }
  }

  const prompt = `${context}

Generate a complete skill structure based on this information.

Respond with a JSON object matching this schema:
{
  "name": "kebab-case-skill-name",
  "description": "Brief description",
  "template": "minimal" | "tool-integration" | "data-processing" | "workflow-automation",
  "templateReasoning": "Why this template was chosen",
  "skillMd": "Complete SKILL.md content with frontmatter",
  "scripts": { "filename.py": "script content" },
  "references": { "filename.md": "reference content" },
  "examples": [
    { "userQuery": "...", "expectedBehavior": "..." }
  ]
}

Requirements:
- Name must be kebab-case, descriptive but concise
- SKILL.md must have YAML frontmatter with name and description
- Include practical examples showing real usage
- Scripts should be complete, runnable code
- Only include scripts/references that are actually needed`}

  try {
    const result = await generateObject({
      model: config.provider,
      schema: {
        type: "object",
        properties: {
          name: { type: "string" },
          description: { type: "string" },
          template: { type: "string", enum: ["minimal", "tool-integration", "data-processing", "workflow-automation"] },
          templateReasoning: { type: "string" },
          skillMd: { type: "string" },
          scripts: { type: "object", additionalProperties: { type: "string" } },
          references: { type: "object", additionalProperties: { type: "string" } },
          examples: {
            type: "array",
            items: {
              type: "object",
              properties: {
                userQuery: { type: "string" },
                expectedBehavior: { type: "string" },
              },
            },
          },
        },
        required: ["name", "description", "template", "skillMd", "examples"],
      },
      messages: [
        { role: "system", content: SKILL_GENERATION_SYSTEM_PROMPT },
        { role: "user", content: prompt },
      ],
      temperature: 0.7,
    })

    return result.object as GeneratedSkill
  } catch (error) {
    log.error("Failed to generate skill", { error, input })
    throw new Error(`Failed to generate skill: ${error instanceof Error ? error.message : String(error)}`)
  }

/**
 * Create skill files from generated structure
 */
export async function createSkillFromGenerated(
  generated: GeneratedSkill,
  targetPath: string
): Promise<string> {
  const skillDir = path.join(targetPath, generated.name)
  
  // Check if exists
  if (await Filesystem.exists(skillDir)) {
    throw new Error(`Skill already exists at ${skillDir}`)
  }

  // Create directories
  await fs.mkdir(skillDir, { recursive: true })
  await fs.mkdir(path.join(skillDir, "scripts"), { recursive: true })
  await fs.mkdir(path.join(skillDir, "references"), { recursive: true })
  await fs.mkdir(path.join(skillDir, "assets"), { recursive: true })

  // Write SKILL.md
  await fs.writeFile(path.join(skillDir, "SKILL.md"), generated.skillMd)

  // Write scripts
  if (generated.scripts) {
    for (const [filename, content] of Object.entries(generated.scripts)) {
      await fs.writeFile(path.join(skillDir, "scripts", filename), content)
    }
  }

  // Write references
  if (generated.references) {
    for (const [filename, content] of Object.entries(generated.references)) {
      await fs.writeFile(path.join(skillDir, "references", filename), content)
    }
  }

  log.info("Created skill from generated structure", {
    name: generated.name,
    template: generated.template,
    path: skillDir,
  })

  return skillDir
}

/**
 * High-level function: interview user and create skill
 */
export async function createSkillWithAI(options: {
  description: string
  interviewAnswers?: { question: string; answer: string }[]
  targetPath: string
  model?: { providerID: string; modelID: string }
  onProgress?: (step: string) => void
}): Promise<{ skillPath: string; generated: GeneratedSkill }> {
  const { description, interviewAnswers, targetPath, model, onProgress } = options

  onProgress?.("Analyzing your requirements...")

  // Generate skill structure
  const generated = await generateSkill({
    userDescription: description,
    interviewQa: interviewAnswers,
    model,
  })

  onProgress?.(`Creating "${generated.name}" using ${generated.template} template...`)

  // Create files
  const skillPath = await createSkillFromGenerated(generated, targetPath)

  onProgress?.("Skill created successfully!")

  return { skillPath, generated }
}

